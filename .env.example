# ---- EntiaBot environment ----

# HTTP port
PORT=3000

# JWT signing secret (used for auth cookies). Change this.
JWT_SECRET=change-me-to-a-long-random-string

# Shared login password for the web UI
APP_PASSWORD=change-me

# Comma-separated list of permitted usernames
APP_USERS=change-me

# API key for Homebridge / external integrations
ENTIA_API_KEY=change-me

# Entia upstream API credentials
ENTIA_BASE_URL=change-me
ENTIA_USERNAME=change-me
ENTIA_PASSWORD=change-me

# Geo coordinates for sunrise/sunset API
SUN_LAT=change-me
SUN_LNG=change-me

# Optional override for data directory (default: ./data)
# DATA_DIR=/var/lib/entiabot
